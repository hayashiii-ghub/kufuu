#!/usr/bin/env bash
# wt — git worktree manager (kufuu pack)
# https://github.com/hayashiii-ghub/kufuu
#
# 7 subcommands: new / ls / status / rm / cleanup / enter / sync
# worktree path: <repo>/.worktrees/<task>/

set -euo pipefail

VERSION="0.1.0"

# ===== style helpers =====
_is_tty()  { [ -t 1 ]; }
_color()   { if _is_tty; then printf '\033[%sm%s\033[0m' "$1" "$2"; else printf '%s' "$2"; fi; }
_bold()    { _color '1'  "$1"; }
_red()     { _color '31' "$1"; }
_green()   { _color '32' "$1"; }
_yellow()  { _color '33' "$1"; }
_dim()     { _color '2'  "$1"; }

# ===== log helpers =====
_log()  { echo "$@" >&2; }
_warn() { echo "$(_yellow warn:) $*" >&2; }
_err()  { echo "$(_red error:) $*" >&2; exit 1; }

# ===== git helpers =====
_require_git_repo() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || _err "not in a git repository"
}

_repo_root() { git rev-parse --show-toplevel; }
_worktrees_dir() { echo "$(_repo_root)/.worktrees"; }
_worktree_path() { echo "$(_worktrees_dir)/$1"; }

_detect_base_branch() {
  local head
  head=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null || true)
  if [ -n "$head" ]; then
    echo "${head#refs/remotes/origin/}"
    return
  fi
  for b in main master; do
    if git show-ref --verify --quiet "refs/heads/$b"; then
      echo "$b"
      return
    fi
  done
  _err "cannot detect base branch (tried origin/HEAD, main, master). use --from"
}

_branch_exists() { git show-ref --verify --quiet "refs/heads/$1"; }

_assert_worktree_exists() {
  local task="$1"
  local p
  p=$(_worktree_path "$task")
  [ -d "$p" ] || _err "worktree not found: $task ($p)"
  echo "$p"
}

_dirty_count() {
  git -C "$1" status --porcelain 2>/dev/null | wc -l | tr -d ' '
}

_ahead_behind() {
  # echoes "<ahead> <behind>" or "0 0" if no upstream
  local wt="$1"
  if ! git -C "$wt" rev-parse --abbrev-ref @{u} >/dev/null 2>&1; then
    echo "0 0"
    return
  fi
  git -C "$wt" rev-list --left-right --count "@{u}...HEAD" 2>/dev/null \
    | awk '{print $2, $1}'
}

# ===== wt new =====
cmd_new() {
  local task="" base="" launch=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --from)   base="$2";   shift 2 ;;
      --launch) launch="$2"; shift 2 ;;
      -*) _err "unknown flag: $1" ;;
      *)  task="$1"; shift ;;
    esac
  done
  [ -n "$task" ] || _err "usage: wt new <task> [--from <base>] [--launch <agent>]"
  _require_git_repo

  [ -z "$base" ] && base=$(_detect_base_branch)
  local path
  path=$(_worktree_path "$task")
  [ -e "$path" ] && _err "path already exists: $path"
  _branch_exists "$task" && _err "branch already exists: $task"

  mkdir -p "$(_worktrees_dir)"
  _log "$(_green +) creating worktree: $path (branch $task from $base)"
  git worktree add -b "$task" "$path" "$base" >&2

  echo "$path"

  if [ -n "$launch" ]; then
    _log "$(_green +) launching: $launch (cwd=$path)"
    (cd "$path" && exec "$launch")
  fi
}

# ===== wt ls =====
cmd_ls() {
  _require_git_repo
  printf "%-32s %-32s %s\n" "$(_bold TASK)" "$(_bold BRANCH)" "$(_bold STATUS)"

  local cur_wt="" cur_branch=""
  while IFS= read -r line; do
    case "$line" in
      "worktree "*)
        [ -n "$cur_wt" ] && _ls_print "$cur_wt" "$cur_branch"
        cur_wt="${line#worktree }"
        cur_branch=""
        ;;
      "branch "*)
        cur_branch="${line#branch refs/heads/}"
        ;;
    esac
  done < <(git worktree list --porcelain)
  [ -n "$cur_wt" ] && _ls_print "$cur_wt" "$cur_branch"
}

_ls_print() {
  local wt="$1" branch="$2"
  local task
  if [[ "$wt" == "$(_worktrees_dir)"/* ]]; then
    task=$(basename "$wt")
  else
    task=$(_dim "(main)")
  fi
  local status_str=""
  local dirty
  dirty=$(_dirty_count "$wt")
  [ "$dirty" -gt 0 ] && status_str+="$(_yellow "dirty:$dirty") "
  local ab
  ab=$(_ahead_behind "$wt")
  local ahead behind
  ahead=$(echo "$ab" | awk '{print $1}')
  behind=$(echo "$ab" | awk '{print $2}')
  [ "$ahead"  != 0 ] && status_str+="$(_green "+$ahead") "
  [ "$behind" != 0 ] && status_str+="$(_red "-$behind") "
  [ -z "$status_str" ] && status_str=$(_dim clean)
  printf "%-32s %-32s %s\n" "$task" "$branch" "$status_str"
}

# ===== wt status =====
cmd_status() {
  local task="${1:-}"
  [ -n "$task" ] || _err "usage: wt status <task>"
  _require_git_repo
  local path
  path=$(_assert_worktree_exists "$task")

  local branch head last dirty
  branch=$(git -C "$path" branch --show-current)
  head=$(git -C "$path" rev-parse --short HEAD)
  last=$(git -C "$path" log -1 --format='%s (%cr)')
  dirty=$(_dirty_count "$path")

  _bold "$task"; echo
  echo "  path:     $path"
  echo "  branch:   $branch ($head)"
  echo "  last:     $last"
  echo "  dirty:    $dirty files"

  local upstream
  upstream=$(git -C "$path" rev-parse --abbrev-ref @{u} 2>/dev/null || true)
  if [ -n "$upstream" ]; then
    local ab ahead behind
    ab=$(_ahead_behind "$path")
    ahead=$(echo "$ab" | awk '{print $1}')
    behind=$(echo "$ab" | awk '{print $2}')
    echo "  upstream: $upstream (ahead $ahead / behind $behind)"
  else
    echo "  upstream: $(_dim "(none)")"
  fi
}

# ===== wt rm =====
cmd_rm() {
  local task="" force=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --force|-f) force=1; shift ;;
      -*) _err "unknown flag: $1" ;;
      *)  task="$1"; shift ;;
    esac
  done
  [ -n "$task" ] || _err "usage: wt rm <task> [--force]"
  _require_git_repo
  local path
  path=$(_assert_worktree_exists "$task")

  local dirty ahead ab
  dirty=$(_dirty_count "$path")
  ab=$(_ahead_behind "$path")
  ahead=$(echo "$ab" | awk '{print $1}')

  if [ "$dirty" -gt 0 ] && [ -z "$force" ]; then
    _err "uncommitted changes in $task ($dirty files). use --force"
  fi
  if [ "$ahead" -gt 0 ] && [ -z "$force" ]; then
    _err "unpushed commits in $task ($ahead). push first or use --force"
  fi

  _log "$(_red -) removing worktree: $path"
  if [ -n "$force" ]; then
    git worktree remove --force "$path"
  else
    git worktree remove "$path"
  fi

  if _branch_exists "$task"; then
    if [ -n "$force" ]; then
      git branch -D "$task" >&2 || true
    else
      git branch -d "$task" >&2 \
        || _warn "branch $task not deleted (unmerged). run: git branch -D $task"
    fi
  fi
}

# ===== wt cleanup =====
cmd_cleanup() {
  local dry_run=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run|-n) dry_run=1; shift ;;
      *) _err "unknown flag: $1" ;;
    esac
  done
  _require_git_repo
  local base
  base=$(_detect_base_branch)
  git fetch origin >&2 2>&1 || true

  local count=0
  while IFS= read -r wt; do
    [ -z "$wt" ] && continue
    [[ "$wt" == "$(_worktrees_dir)"/* ]] || continue
    local task
    task=$(basename "$wt")
    # branch が base に merged 済か
    if git merge-base --is-ancestor "$task" "$base" 2>/dev/null; then
      local dirty
      dirty=$(_dirty_count "$wt")
      if [ "$dirty" -gt 0 ]; then
        _warn "skip $task: merged but has uncommitted changes"
        continue
      fi
      if [ -n "$dry_run" ]; then
        echo "would remove: $task ($(_dim "merged into $base"))"
      else
        _log "$(_red -) removing $task (merged)"
        git worktree remove "$wt" >&2
        git branch -D "$task" >&2 || true
      fi
      count=$((count+1))
    fi
  done < <(git worktree list --porcelain | awk '/^worktree / {print $2}')

  [ "$count" -eq 0 ] && _log "$(_dim "no merged worktrees found")"
}

# ===== wt enter =====
cmd_enter() {
  local task="" launch=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --launch) launch="$2"; shift 2 ;;
      -*) _err "unknown flag: $1" ;;
      *)  task="$1"; shift ;;
    esac
  done
  [ -n "$task" ] || _err "usage: wt enter <task> [--launch <agent>]"
  _require_git_repo
  local path
  path=$(_assert_worktree_exists "$task")

  if [ -n "$launch" ]; then
    _log "$(_green +) launching: $launch (cwd=$path)"
    (cd "$path" && exec "$launch")
  else
    _log "$(_dim "cd into:") $path"
    echo "$path"
  fi
}

# ===== wt sync =====
cmd_sync() {
  local task="${1:-}"
  _require_git_repo
  local base
  base=$(_detect_base_branch)
  git fetch origin >&2 2>&1 || true

  if [ -z "$task" ]; then
    while IFS= read -r wt; do
      [[ "$wt" == "$(_worktrees_dir)"/* ]] || continue
      _sync_one "$wt" "$base"
    done < <(git worktree list --porcelain | awk '/^worktree / {print $2}')
  else
    local path
    path=$(_assert_worktree_exists "$task")
    _sync_one "$path" "$base"
  fi
}

_sync_one() {
  local wt="$1" base="$2"
  local name
  name=$(basename "$wt")
  local dirty
  dirty=$(_dirty_count "$wt")
  if [ "$dirty" -gt 0 ]; then
    _warn "skip $name: uncommitted changes"
    return
  fi
  _log "$(_green ">") syncing $name with origin/$base"
  git -C "$wt" rebase "origin/$base" >&2 \
    || _warn "rebase failed in $name. run: git -C $wt rebase --abort"
}

# ===== wt help / version =====
cmd_help() {
  cat <<'EOF'
wt — git worktree manager (kufuu pack)

usage:
  wt new <task> [--from <base>] [--launch <agent>]
      新規 worktree 作成、branch 切り、path を stdout に出力
      --from 省略時は origin/HEAD → main → master を自動検出
      --launch <agent> 指定時、その worktree で agent 起動 (例: --launch claude)

  wt ls
      worktree 一覧 (task / branch / dirty / ahead / behind)

  wt status <task>
      指定 worktree の詳細

  wt rm <task> [--force]
      worktree 削除 + branch 削除
      未 commit / 未 push があると拒否、--force で強制

  wt cleanup [--dry-run]
      base に merge された worktree を自動削除
      --dry-run で削除候補のみ表示

  wt enter <task> [--launch <agent>]
      worktree の path を stdout に出力
      cd 例: cd "$(wt enter <task>)"

  wt sync [<task>]
      指定 (省略時は全) worktree を origin/<base> で rebase

  wt version | -V | --version
      バージョン表示

  wt help | -h | --help
      このヘルプ

設計:
  worktree path は .worktrees/<task>/ (repo 内)、.gitignore 推奨
  詳細は https://github.com/hayashiii-ghub/kufuu
EOF
}

cmd_version() { echo "wt $VERSION (kufuu)"; }

# ===== dispatcher =====
sub="${1:-help}"
shift || true
case "$sub" in
  new)                    cmd_new     "$@" ;;
  ls|list)                cmd_ls      "$@" ;;
  status)                 cmd_status  "$@" ;;
  rm|remove)              cmd_rm      "$@" ;;
  cleanup)                cmd_cleanup "$@" ;;
  enter)                  cmd_enter   "$@" ;;
  sync)                   cmd_sync    "$@" ;;
  help|-h|--help)         cmd_help         ;;
  version|-V|--version)   cmd_version      ;;
  *) _err "unknown subcommand: $sub (use 'wt help')" ;;
esac
